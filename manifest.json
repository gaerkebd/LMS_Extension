{
  "manifest_version": 3,
  "name": "Canvas LMS Time Estimator",
  "version": "1.1.0",
  "description": "AI-powered time estimation for Canvas LMS assignments. View your to-do list with estimated completion times.",
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://api.openai.com/*",
    "https://www.googleapis.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instructure.com/*"],
      "js": ["src/content/content-script.ts"],
      "css": ["content-styles.css"]
    },
    {
      "matches": ["https://*.instructure.com/*"],
      "js": ["src/content/sidebar-injector.tsx"],
      "css": ["sidebar-styles.css"]
    }
  ],
  "options_page": "src/options/index.html",
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  }
}
